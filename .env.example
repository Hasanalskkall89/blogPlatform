# Docker Compose Environment Variables
COMPOSE_PROJECT_NAME=blog

# Database Configuration
POSTGRES_DB=blog_db
POSTGRES_USER=blog_user
POSTGRES_PASSWORD=your_secure_password

# Domain Configuration
DOMAIN=blog.com
ADMIN_DOMAIN=admin.blog.com

# SSL Configuration
SSL_EMAIL=your_email@example.com

# Application Ports
FRONTEND_PORT=3000
BACKEND_PORT=5000
ADMIN_PORT=3001

# Security
JWT_SECRET=your_jwt_secret_key

# API Configuration
API_PREFIX=/api
NODE_ENV=production