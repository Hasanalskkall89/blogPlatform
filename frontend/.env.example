# Environment
NODE_ENV=development

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Image Domains
NEXT_PUBLIC_ALLOWED_IMAGE_DOMAINS=localhost,media.example.com

# Server Actions
NEXT_PUBLIC_ALLOWED_ORIGINS=localhost:3000,example.com

# Contact Information
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# Media Configuration
NEXT_PUBLIC_MEDIA_URL=http://localhost:5000/media

# Build Configuration
NEXT_PUBLIC_ENABLE_SOURCE_MAPS=true
NEXT_PUBLIC_ENABLE_TYPE_CHECKING=false
NEXT_PUBLIC_ENABLE_ESLINT=false

# Cache Configuration
NEXT_PUBLIC_IMAGE_CACHE_TTL=60