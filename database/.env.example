# Database Configuration
POSTGRES_DB=blog
POSTGRES_USER=admin
POSTGRES_PASSWORD=BlogAdmin@2024!
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SSL Configuration
POSTGRES_SSL=true
POSTGRES_SSL_CERT=/var/lib/postgresql/server.crt
POSTGRES_SSL_KEY=/var/lib/postgresql/server.key
POSTGRES_SSL_MODE=verify-full

# Backup Configuration
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=7

# Docker Configuration
CONTAINER_NAME=blog-db
DATA_VOLUME_NAME=blog-data
BACKUP_VOLUME_NAME=blog-backups

# Network Configuration
NETWORK_NAME=blog-network
