{
  "containerName": "blog-db",
  "image": {
    "name": "blog-db",
    "tag": "latest",
    "buildCommand": "docker build -t blog-db:latest ."
  },
  "run": {
    "command": "docker run",
    "options": {
      "name": "blog-db",
      "detach": true,
      "restart": "unless-stopped",
      "port": "5432:5432",
      "environment": {
        "POSTGRES_DB": "${DB_NAME}",
        "POSTGRES_USER": "${DB_USER}",
        "POSTGRES_PASSWORD": "${DB_PASSWORD}"
      },
      "volumes": [
        {
          "name": "blog-data",
          "containerPath": "/var/lib/postgresql/data",
          "description": "Persistent storage for database files"
        },
        {
          "name": "blog-backups",
          "containerPath": "/backups",
          "description": "Directory for database backups"
        }
      ]
    }
  },
  "maintenance": {
    "backup": {
      "command": "docker exec blog-db pg_dump -U ${DB_USER} ${DB_NAME} > ./backups/backup_$(date +%Y%m%d_%H%M%S).sql",
      "schedule": "0 0 * * *",
      "description": "Daily backup at midnight"
    },
    "restore": {
      "command": "docker exec -i blog-db psql -U ${DB_USER} ${DB_NAME} < ./backups/[backup_file_name].sql",
      "description": "Restore database from backup file"
    }
  },
  "commands": {
    "build": "docker build -t blog-db:latest .",
    "start": "docker run -d --name blog-db --restart unless-stopped -p 5432:5432 -v blog-data:/var/lib/postgresql/data -v blog-backups:/backups -e POSTGRES_DB=${DB_NAME} -e POSTGRES_USER=${DB_USER} -e POSTGRES_PASSWORD=${DB_PASSWORD} blog-db:latest",
    "stop": "docker stop blog-db",
    "remove": "docker rm blog-db",
    "logs": "docker logs blog-db",
    "shell": "docker exec -it blog-db bash",
    "psql": "docker exec -it blog-db psql -U ${DB_USER} ${DB_NAME}"
  },
  "volumes": {
    "data": {
      "name": "blog-data",
      "driver": "local",
      "description": "Persistent volume for PostgreSQL data"
    },
    "backups": {
      "name": "blog-backups",
      "driver": "local",
      "description": "Volume for storing database backups"
    }
  },
  "initialization": {
    "steps": [
      {
        "description": "Create Docker volumes",
        "commands": [
          "docker volume create blog-data",
          "docker volume create blog-backups"
        ]
      },
      {
        "description": "Build database image",
        "command": "docker build -t blog-db:latest ."
      },
      {
        "description": "Start database container",
        "command": "docker run -d --name blog-db --restart unless-stopped -p 5432:5432 -v blog-data:/var/lib/postgresql/data -v blog-backups:/backups -e POSTGRES_DB=${DB_NAME} -e POSTGRES_USER=${DB_USER} -e POSTGRES_PASSWORD=${DB_PASSWORD} blog-db:latest"
      }
    ]
  }
}
